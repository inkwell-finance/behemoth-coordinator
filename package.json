{
  "name": "@behemoth/coordinator",
  "version": "0.1.0",
  "description": "Behemoth coordinator node - research gateway and job distribution",
  "private": true,
  "type": "module",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "bun": "node --loader ts-node/esm scripts/${BUN_SCRIPT:-start}.ts",
    "test": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@inkwell-finance/protocol": "^0.1.0",
    "@chainsafe/libp2p-gossipsub": "^14.1.2",
    "@chainsafe/libp2p-noise": "^17.0.0",
    "@chainsafe/libp2p-yamux": "^8.0.1",
    "@grpc/grpc-js": "^1.10.0",
    "@grpc/proto-loader": "^0.7.0",
    "@libp2p/identify": "^4.0.13",
    "@libp2p/kad-dht": "^16.1.6",
    "@libp2p/ping": "^3.0.13",
    "@libp2p/tcp": "^11.0.13",
    "@multiformats/multiaddr": "^13.0.1",
    "ioredis": "^5.3.0",
    "libp2p": "^3.1.6",
    "pino": "^8.16.0",
    "yaml": "^2.3.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
